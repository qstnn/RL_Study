+    class RSLRL2Wrapper:
+        def __init__(self, env):
+            self.env = env
+            
+        def __getattr__(self, name):
+            # 透传所有底层属性
+            return getattr(self.env, name)
+            
+        def _extract(self, obs):
+            # 将新版 IsaacLab 的字典外壳剥离，返回纯 Tensor
+            if isinstance(obs, dict):
+                return obs.get("policy", list(obs.values())[0])
+            return obs
+
+        @property
+        def obs_buf(self):
+            return self._extract(self.env.obs_buf)
+            
+        def get_observations(self):
+            ret = self.env.get_observations()
+            return (self._extract(ret[0]),) + ret[1:]
+            
+        def reset(self):
+            ret = self.env.reset()
+            return (self._extract(ret[0]),) + ret[1:]
+            
+        def step(self, actions):
+            ret = self.env.step(actions)
+            return (self._extract(ret[0]),) + ret[1:]
+
